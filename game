#-----------
# bibliotecas
import pgzero
from pgzero.actor import Actor

#-----------

#-----------
# variáveis
FPS = 30
WIDTH = 800
HEIGHT = 600

reputacao = 30
dinheiro = 500
vida = 100
mana = 100
#-----------

#-----------
# sprites

trilhaInicial = None
trilhaSegundaria = None
trilhaTerciaria = None
trilhaVila = None

fundoAmarelo = None
fundoRoxo = None
fundoCiano = None
fundoVinho = None

fundo_atual = None

quest = None
character = None

#-----------

#-----------
# carregando sprites

def ensure_sprites():

    global trilhaInicial
    global trilhaSegundaria
    global trilhaTerciaria
    global trilhaVila

    global fundoAmarelo
    global fundoRoxo
    global fundoCiano
    global fundoVinho

    global fundo_atual
    global quest
    global character

    # evita recriar tudo toda hora
    if character is not None:
        return

    trilhaInicial = Actor("trilhainicial")
    trilhaSegundaria = Actor("segundasegundaria")
    trilhaTerciaria = Actor("trilhaterciaria")
    trilhaVila = Actor("trilhavila")

    fundoAmarelo = Actor("fundoamarelo")
    fundoRoxo = Actor("fundoroxo")
    fundoCiano = Actor("fundociano")
    fundoVinho = Actor("fundovinho")

    fundo_atual = trilhaInicial

    quest = Actor("questbg", (730, 70))
    character = Actor("characterbg", (400, 300))

#-----------


#-----------
# draw

def draw():

    ensure_sprites()

    screen.clear()

    if fundo_atual is not None:
        fundo_atual.draw()

    if quest is not None:
        quest.draw()

    if character is not None:
        character.draw()

    screen.draw.text(
        "missão",
        (650, 55),
        fontsize=40,
        color="white"
    )

    screen.draw.text(
        "reputação: " + str(reputacao),
        (30, 20),
        fontsize=30,
        color="white"
    )

    screen.draw.text(
        "dinheiro: " + str(dinheiro),
        (30, 50),
        fontsize=30,
        color="white"
    )

    screen.draw.text(
        "vida: " + str(vida),
        (30, 80),
        fontsize=30,
        color="white"
    )

    screen.draw.text(
        "mana: " + str(mana),
        (30, 110),
        fontsize=30,
        color="white"
    )

#-----------


#-----------
# update

def update():

    global fundo_atual

    ensure_sprites()

    # segurança extra
    if character is None:
        return

    velocidade = 5

    #-----------
    # movimentação

    if keyboard.left or keyboard.a:
        character.x -= velocidade

    if keyboard.right or keyboard.d:
        character.x += velocidade

    if keyboard.up or keyboard.w:
        character.y -= velocidade

    if keyboard.down or keyboard.s:
        character.y += velocidade

    #-----------
    # mapa principal

    if fundo_atual == trilhaInicial:

        # esquerda
        if character.x <= 0:
            character.x = 0
            screen.draw.text(
                "chegou nos limites desta tela",
                (30, 30),
                fontsize = 60,
                color = "red"
            )

        # direita
        elif character.x >= WIDTH:
            character.x = WIDTH
            screen.draw.text("cegou nos limites desta tela",
                             (30, 30),
                             fontsize = 60,
                             color = "red")

        # cima
        elif character.y <= 0:
            fundo_atual = trilhaTerciaria
            character.y = HEIGHT - 50

        # baixo
        elif character.y >= HEIGHT:
            fundo_atual = trilhaSegundaria
            character.y = 50

    #-----------
    # trilha secundaria

   

    #-----------
 
    #-----------
    # trilha terciaria

    elif fundo_atual == trilhaTerciaria:

        if character.y >= HEIGHT:
            fundo_atual = trilhaInicial
            character.y = 50

    #-----------
    # para baixo

    if fundo_atual == trilhaSegundaria:

        #voltar pro mapa inicial
        if character.y <= 0:
            fundo_atual = trilhaInicial
            character.y = HEIGHT - 50
        
        if character.y >= HEIGHT:
            character.y = 550

        #limite esquerdo
        elif character.x <= 0:
            character.x = 0

        #ir para o ciano 
        elif character.x >=WIDTH:
            fundo_atual = trilhaVila
            character.x = 50

    #-----------
    # fundo ciano

    elif fundo_atual == trilhaVila:

        # voltar pro roxo
        if character.x <= 0:
            fundo_atual = trilhaSegundaria
            character.x = WIDTH - 50

        # ir pro vinho
        elif character.x >= WIDTH:
            fundo_atual = fundoVinho
            character.x = 50
        
        elif character.y <=0:
            character.y = 50
        
        elif character.y >=550:
            character.y = 500

    #-----------
    # fundo vinho

    elif fundo_atual == fundoVinho:

        if character.x <= 0:
            fundo_atual = trilhaVila
            character.x = WIDTH - 50

#-----------


#-----------
# rodar jogo

if __name__ == "__main__":
    import pgzrun
    pgzrun.go()

#-----------
